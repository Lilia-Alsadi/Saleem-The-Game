  ui: {fileID: 8535772635836384212}
  headForwardText: "\uFEB1\uFE83\uFEAD \uFE94\uFEDF\uFE8E\uFEE3\uFE88\uFE91 \uFEDA\uFEF4\uFEE0\uFECB
    \n\uFEE1\uFE8E\uFEE3\uFEFB\uFE8D \uFEF0\uFEDF\uFE8D \uFE8F\uFE8E\uFEBC\uFEE4\uFEDF\uFE8D
    \uFEBA\uFEA8\uFEB8\uFEDF\uFE8D "
  pinchHoldText: "\uFED2\uFEE7\uFEF7\uFE8D \uFEF0\uFEE0\uFECB \uFEC2\uFED0\uFEBF\uFE8D\n\uFED9\uFEAE\uFE98\uFE97
    \uFE8E\uFEE3 \uFEE5\uFEED\uFEAA\uFE91 \uFEF2\uFEE7\uFE8D\uFEEE\uFE9B 10 \uFE93\uFEAA\uFEE4\uFEDF "
  sheetsText: "\uFEF2\uFE92\uFEC4\uFEDF\uFE8D \uFEDE\uFEF3\uFEAA\uFEE8\uFEE4\uFEDF\uFE8D
    \uFECA\uFEC4\uFED7 \uFEE1\uFEAA\uFEA8\uFE98\uFEB3\uFE8D\n\uFED2\uFEE7\uFEF7\uFE8D
    \uFEE6\uFEE3 \uFEE1\uFEAA\uFEDF\uFE8D \uFED2\uFEF4\uFEC8\uFEE8\uFE98\uFEDF"
  bandAidText: "\uFEE2\uFED8\uFECC\uFEE4\uFEDF\uFE8D \uFEF2\uFE92\uFEC4\uFEDF\uFE8D
    \uFEE6\uFEC4\uFED8\uFEDF\uFE8D \uFE94\uFED4\uFEDF \uFECA\uFEBF\n\uFED2\uFEF3\uFEB0\uFEE8\uFEDF\uFE8D
