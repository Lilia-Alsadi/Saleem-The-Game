--- !u!114 &6998674917252550852
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6403975426286973679}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: UnityEngine.UI::UnityEngine.UI.Text
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 0.9716981, b: 0.9716981, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 68
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 68
    m_Alignment: 4
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\uFEDE\uFEE4\uFECC\uFEDF\uFE8D \uFED6\uFEF3\uFEAE\uFED3\n:\uFEF1\uFEA9\uFE8D\uFEEE\uFEE0\uFEB4
    \u0627\uFEE3\uFE8D\uFEAD\n.\uFEF2\uFE97\uFEEE\uFEBB \uFE80\uFE8D\uFEA9\uFE83\uFEED
    \u060C\uFEF2\uFEA0\uFEE3\uFEAE\uFE92\uFEDF\uFE8D \uFED6\uFEC4\uFEE8\uFEE4\uFEDF\uFE8D
    \u060C\uFEC2\uFE8B\uFE8D\uFEAE\uFEA8\uFEDF\uFE8D \uFEE2\uFEF4\uFEE4\uFEBC\uFE97
    \u060C\uFEC9\uFEED\uFEAE\uFEB8\uFEE4\uFEDF\uFE8D \uFE93\uFEAA\uFE8B\uFE8E\uFED7
    \n\n:\uFEF1\uFEAA\uFECC\uFEB4\uFEDF\uFE8D \uFE8E\uFEF4\uFEE0\uFEF4\uFEDF\n\uFEE2\uFEF4\uFEE4\uFEBC\uFE97
    \u060C\uFEE1\uFEAA\uFEA8\uFE98\uFEB4\uFEE4\uFEDF\uFE8D \uFE94\uFEEC\uFE9F\uFE8D\uFEED
    \uFEE2\uFEF4\uFEE4\uFEBC\uFE97 \n.\uFEF2\uFE97\uFEEE\uFEBB \uFE80\uFE8D\uFEA9\uFE83\uFEED
    \u060C\uFE94\uFEF4\uFE8B\uFE8E\uFEE4\uFEE8\uFEF4\uFEB4\uFEDF\uFE8D \uFEAA\uFEEB\uFE8E\uFEB8\uFEE4\uFEDF\uFE8D
    \uFE94\uFECB\uFE8E\uFEE8\uFEBB \u060C\uFE9D\uFEAB\uFE8E\uFEE4\uFEE8\uFEDF\uFE8D
    \uFE80\uFE8E\uFEB4\uFEDB\uFE87 \u060C\uFE95\uFE8E\uFEF4\uFEBC\uFEA8\uFEB8\uFEDF\uFE8D
    \n\n\uFE90\uFEDF\uFE8E\uFEC3 \uFEEE\uFE91\uFE83 \uFEE6\uFEE4\uFEA3\uFEAE\uFEDF\uFE8D
    \uFEAA\uFE92\uFECB\n.\uFEF2\uFE97\uFEEE\uFEBB \uFE80\uFE8D\uFEA9\uFE83\uFEED
    \u060C\uFEF2\uFEA0\uFEE3\uFEAE\uFE92\uFEDF\uFE8D \uFED6\uFEC4\uFEE8\uFEE4\uFEDF\uFE8D
    :\n\n\uFEF2\uFEE4\uFEF3\uFEA9\uFE8E\uFEDB\uFEF7\uFE8D \uFED1\uFE8D\uFEAE\uFEB7\uFEF9\uFE8D\n.\uFEC9\uFEED\uFEAE\uFEB8\uFEE4\uFEDF\uFE8D
    \uFED1\uFEAE\uFEB8\uFEE3 :\uFEDE\uFEF4\uFE9F \uFEEE\uFE91\uFE83 \uFED2\uFEF3\uFE8E\uFEE7
    \uFEAD\uFEEE\uFE98\uFEDB\uFEAA\uFEDF\uFE8D\n\n\uFE94\uFECC\uFEE3\uFE8E\uFEA0\uFEDF\uFE8D\nHTU
    \uFE94\uFEF4\uFEE8\uFED8\uFE98\uFEDF\uFE8D \uFEE6\uFEF4\uFEB4\uFEA4\uFEDF\uFE8D
    \uFE94\uFECC\uFEE3\uFE8E\uFE9F\n\n\uFEAE\uFEF3\uFEEE\uFEC4\uFE98\uFEDF\uFE8D
    \uFE95\uFE8D\uFEED\uFEA9\uFE83\nBlender\nUnity\nCanva \n\n\uFEB9\uFE8E\uFEA7
    \uFEAE\uFEDC\uFEB7\n\uFEDA\uFEF4\uFEF4\uFEE8\uFEB8\uFEDF\uFE8D \uFEE5\uFEB0\uFEF3
    \uFEB1\uFEAA\uFEE8\uFEEC\uFEE4\uFEDF\uFE8D\n(Gaming lab) \uFE8F\uFE8E\uFECC\uFEDF\uFEF7\uFE8D
    \uFEAE\uFE92\uFE98\uFEA8\uFEE3\n.\uFEAE\uFEE4\uFE98\uFEB4\uFEE4\uFEDF\uFE8D \uFEE2\uFEEC\uFEE4\uFECB\uFEA9
    \uFEF0\uFEE0\uFECB \uFE8E\uFEE7\uFE85\uFE8E\uFED7\uFEAA\uFEBB\uFE83\uFEED \uFE8E\uFEE8\uFE97\uFEFC\uFE8B\uFE8E\uFECB"
